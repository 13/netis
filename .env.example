# Netis environment configuration
#
# Default — SQLite, data volume mounted at /data inside the backend container:
NETIS_DATABASE_URL=sqlite:////data/netis.db

# PostgreSQL example (use with: docker compose --profile postgres up -d):
# NETIS_DATABASE_URL=postgresql+psycopg://netis:netis@postgres:5432/netis

# REQUIRED: change this to a long random string before exposing externally.
NETIS_SECRET_KEY=please-change-me-to-a-long-random-string

NETIS_ACCESS_TOKEN_EXPIRE_MINUTES=1440
NETIS_CORS_ORIGINS=http://localhost:8080
